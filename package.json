    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.3",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.7.0"
  },
  "workspaces": [
    "extensions/*"
  ],
